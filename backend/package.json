{
  "name": "pragyan-backend",
  "version": "1.0.0",
  "description": "AI-powered career guidance platform backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node -r module-alias/register dist/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "seed": "tsx prisma/seed.ts",
    "seed:roadmaps": "tsx scripts/seedRoadmapCatalog.ts",
    "db:create-roadmap-index": "tsx scripts/createTextIndexes.ts",
    "sync-admin-email": "tsx scripts/syncAdminEmail.ts",
    "verify-admin-email": "tsx scripts/verifyAdminEmail.ts",
    "test": "jest --runInBand --detectOpenHandles --coverage",
    "ci": "npm run build && npm test"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@prisma/client": "^5.22.0",
    "axios": "^1.16.1",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.2",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.19.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "module-alias": "^2.3.4",
    "mongodb": "^7.2.0",
    "morgan": "^1.10.0",
    "node-cron": "^4.2.1",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "pragyan": "file:..",
    "redis": "^4.6.7",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.19.0",
    "@types/jest": "^29.5.3",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.10.6",
    "@types/passport": "^1.0.17",
    "@types/passport-github2": "^1.2.9",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/supertest": "^2.0.12",
    "jest": "^29.7.0",
    "prisma": "^5.22.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "_moduleAliases": {
    "@": "./dist",
    "@lib": "./dist/lib",
    "@config": "./dist/config",
    "@ai": "./dist/ai",
    "@services": "./dist/services",
    "@utils": "./dist/utils",
    "@middleware": "./dist/middleware"
  }
}
