generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ============ USER MODELS ============

model User {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  email            String   @unique
  fullName         String
  password         String
  provider         String   @default("local")
  providerId       String?
  avatar           String?
  emailVerified    Boolean  @default(false)
  role             String   @default("USER")
  age              Int?
  location         String?
  phone            String?
  linkedin         String?
  skills           String[]
  interests        String[]
  preferences      String[]
  experience       String?
  experienceType   String?  @default("fresher")
  education        String?
  educationEntries Json?
  skillLevel       String?
  xp               Float    @default(0)
  streak           Int      @default(0)
  level            Int      @default(1)
  currentTitle     String?
  careerTrack      String?

  // Relations
  refreshTokens           RefreshToken[]
  socialAccounts          SocialAccount[]
  githubRepositories      GithubRepository[]
  portfolioProjects       UserPortfolioProject[]
  certifications          UserCertification[]
  assessmentAnswers       AssessmentAnswer[]
  assessmentResults       AssessmentResult[]
  assessmentSessions      AssessmentSession[]
  progress                UserProgress[]
  completedRoadmaps       CompletedRoadmap[]
  completedTaskHistory    CompletedTaskHistory[]
  achievements            UserAchievement[]
  userXpLogs              UserXpLog[]
  dailyQuizAttempts       DailyQuizAttempt[]
  dailyLearning           UserDailyLearning[]
  userRoadmaps            UserRoadmap[]
  taskProgress            TaskProgress[]
  resourceLearningHistory  ResourceLearningHistory[]
  careerMatches           CareerMatch[]
  jobApplications         JobApplication[]
  dailyAnalyticsSnapshots  DailyAnalyticsSnapshot[]
  // AI Memory & Personalization relations
  aiMemoryProfiles        AIMemoryProfile[]
  recommendationHistories RecommendationHistory[]
  recommendationSnapshots RecommendationSnapshot[]
  roadmapMutations        RoadmapMutation[]
  personalityProfiles     PersonalityProfile[]
  learningVelocities      LearningVelocity[]
  decisionSnapshots       DecisionSnapshot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([provider, providerId])
}

// Intelligence debug audit logs for admin access to sensitive intelligence payloads
model IntelligenceDebugAudit {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  adminId    String   @db.ObjectId
  targetUser String?  @db.ObjectId
  endpoint   String
  filters    Json?
  env        String?
  createdAt  DateTime @default(now())

  @@index([adminId])
  @@index([targetUser])
}

model SocialAccount {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @db.ObjectId
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider      String
  providerId    String
  email         String?
  username      String?
  avatar        String?
  accessToken   String?
  refreshToken  String?
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([provider, providerId])
  @@index([userId])
}

model GithubRepository {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @db.ObjectId
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  repoId        String
  name          String
  fullName      String
  htmlUrl       String
  description   String?
  language      String?
  stars         Int      @default(0)
  forks         Int      @default(0)
  isPrivate     Boolean  @default(false)
  defaultBranch String?
  pushedAt      DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, repoId])
  @@index([userId])
}

model UserPortfolioProject {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  techStack   String[] @default([])
  highlights  String[] @default([])
  liveUrl     String?
  repoUrl     String?
  featured    Boolean  @default(false)
  source      String   @default("manual")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model UserCertification {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @db.ObjectId
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String
  issuer        String
  credentialId  String?
  credentialUrl String?
  issuedAt      DateTime?
  expiresAt     DateTime?
  description   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model RefreshToken {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  token     String   @unique
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime

  createdAt DateTime @default(now())

  @@index([userId])
}

model PasswordResetOTP {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String?  @db.ObjectId
  email     String
  otpHash   String
  expiresAt DateTime
  attempts  Int      @default(0)
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([expiresAt])
}

// ============ SKILL & ROADMAP MODELS ============

model Skill {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  skillName      String   @unique
  skillCategory  String
  difficulty     String
  description    String
  totalDuration  String
  estimatedHours Int
  icon           String
  color          String
  prerequisites  String[]
  relatedSkills  String[]
  totalDays      Int

  // Relations
  weeklyModules WeeklyModule[]
  dailyTasks    DailyTask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DailyTask {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  skillId       String   @db.ObjectId
  skill         Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  taskNumber    Int
  title         String
  description   String
  estimatedTime String
  subtasks      String[]
  xp            Int      @default(0)

  // Relations
  resources    Resource[]
  taskProgress TaskProgress[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([skillId])
}

model WeeklyModule {
  id           String  @id @default(auto()) @map("_id") @db.ObjectId
  skillId      String  @db.ObjectId
  skill        Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  moduleNumber Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([skillId])
}

model Resource {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  taskId      String    @db.ObjectId
  task        DailyTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  title       String
  url         String
  description String?
  platform    String
  type        String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId])
}

model LearningResource {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  resourceKey      String   @unique
  roadmapId        String?  @db.ObjectId
  roadmap          Roadmap? @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  roadmapCategory  String
  roadmapTitle     String?
  skill            String
  topic            String
  topicSlug        String
  dayNumber        Int?
  resourceType     String
  difficulty       String
  source           String   @default("curated")
  title            String
  url              String
  description      String
  provider         String
  estimatedMinutes Int?
  isOfficial       Boolean  @default(false)
  aiScore          Float    @default(0)
  tags             String[]
  metadata         Json?

  history ResourceLearningHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([roadmapId])
  @@index([roadmapCategory])
  @@index([skill])
  @@index([topic])
  @@index([resourceType])
  @@index([difficulty])
}

model ResourceLearningHistory {
  id              String           @id @default(auto()) @map("_id") @db.ObjectId
  userId          String           @db.ObjectId
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  resourceId      String           @db.ObjectId
  resource        LearningResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  roadmapId       String?          @db.ObjectId
  roadmap         Roadmap?         @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  completed       Boolean          @default(false)
  progressPercent Int              @default(0)
  quizScore       Float?
  notes           String?
  source          String           @default("manual")
  completedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, resourceId])
  @@index([userId])
  @@index([roadmapId])
}

model TaskProgress {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  userId      String    @db.ObjectId
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskId      String    @db.ObjectId
  task        DailyTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  completed   Boolean   @default(false)
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, taskId])
  @@index([userId])
  @@index([taskId])
}

// ============ LEGACY ROADMAP MODELS ============

model Roadmap {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  title          String
  category       String
  careerPath     String?
  difficulty     String?
  description    String
  level          String
  duration       String
  icon           String
  estimatedHours Int
  requiredSkills String[] @default([])
  learningStructure Json?
  milestones     Json?
  progression    Json?
  tags           String[]

  // Relations
  weeks             Week[]
  learningResources LearningResource[]
  resourceLearningHistory ResourceLearningHistory[]
  userRoadmaps      UserRoadmap[]
  progress          UserProgress[]
  completedRoadmaps CompletedRoadmap[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Week {
  id         String  @id @default(auto()) @map("_id") @db.ObjectId
  roadmapId  String  @db.ObjectId
  roadmap    Roadmap @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  title      String
  weekNumber Int

  // Relations
  days Day[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([roadmapId])
}

model Day {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  weekId      String  @db.ObjectId
  week        Week    @relation(fields: [weekId], references: [id], onDelete: Cascade)
  title       String
  dayNumber   Int
  description String?

  // Relations
  tasks Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([weekId])
}

model Task {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  dayId       String  @db.ObjectId
  day         Day     @relation(fields: [dayId], references: [id], onDelete: Cascade)
  title       String
  description String
  duration    String
  completed   Boolean @default(false)
  xp          Int     @default(10)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dayId])
}

model UserRoadmap {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  userId    String  @db.ObjectId
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  roadmapId String  @db.ObjectId
  roadmap   Roadmap @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  progress  Float   @default(0)
  started   Boolean @default(false)
  completed Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, roadmapId])
  @@index([userId])
  @@index([roadmapId])
}

// ============ ASSESSMENT MODELS ============

model Assessment {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String?

  // Relations
  questions AssessmentQuestion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AssessmentQuestion {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  assessmentId String     @db.ObjectId
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  questionText String
  options      String[]
  category     String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assessmentId])
}

model AssessmentAnswer {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  userId   String @db.ObjectId
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  question String
  answer   String
  category String

  createdAt DateTime @default(now())

  @@index([userId])
}

model AssessmentResult {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  userId           String   @db.ObjectId
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers          String
  suggestedCareers String[]
  scores           String
  strengths        String[]
  weaknesses       String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model AssessmentSession {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  userId          String   @db.ObjectId
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers         String
  selectedOptions String[]
  analysis        String
  completedAt     DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([completedAt])
}

// Persisted decision-tree assessment path for each user session
model AssessmentPath {
  id                   String   @id @default(auto()) @map("_id") @db.ObjectId
  userId               String   @db.ObjectId
  assessmentSessionId  String?  

  selectedCategory     String?
  selectedSector       String?
  selectedQualification String?
  selectedBranch       String?
  selectedRole         String?

  finalCareerPath      String
  confidence           Int?

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([userId])
}

model UserProgress {
  id                 String    @id @default(auto()) @map("_id") @db.ObjectId
  userId             String    @db.ObjectId
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  roadmapId          String    @db.ObjectId
  roadmap            Roadmap   @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  completedTasks     String[]  @default([])
  completedDays      String[]  @default([])
  progressPercentage Float     @default(0)
  currentDay         Int       @default(1)
  xp                 Int       @default(0)
  streak             Int       @default(0)
  lastActiveDate     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, roadmapId])
  @@index([userId])
  @@index([roadmapId])
}

model CompletedRoadmap {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roadmapId   String   @db.ObjectId
  roadmap     Roadmap  @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  completedAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([roadmapId])
}

model CompletedTaskHistory {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskId      String
  roadmapId   String?
  xpAwarded   Int      @default(0)
  completedAt DateTime @default(now())

  createdAt DateTime @default(now())

  @@unique([userId, taskId])
  @@index([userId])
  @@index([roadmapId])
}

model UserAchievement {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  code        String
  title       String
  description String
  unlockedAt  DateTime @default(now())

  createdAt DateTime @default(now())

  @@unique([userId, code])
  @@index([userId])
}

model UserXpLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Int
  reason    String
  meta      Json?
  createdAt DateTime @default(now())

  @@index([userId])
}

model DailyQuiz {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  roadmapId   String?  @db.ObjectId
  title       String
  description String?
  questions   Json
  attempts    DailyQuizAttempt[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DailyQuizAttempt {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  quizId    String   @db.ObjectId
  quiz      DailyQuiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  score     Int
  xpAwarded Int      @default(0)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([quizId])
}

model UserDailyLearning {
  id             String @id @default(auto()) @map("_id") @db.ObjectId
  userId         String @db.ObjectId
  user           User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  date           String
  tasksCompleted Int    @default(0)
  xpEarned       Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId])
}

model DailyAnalyticsSnapshot {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  userId          String   @db.ObjectId
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date            String
  readinessScore  Float    @default(0)
  xp              Int      @default(0)
  streak          Int      @default(0)
  completedTasks  Int      @default(0)
  studyHours      Float    @default(0)
  eligibleJobs    Int      @default(0)
  weakSkillCount  Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

// ============ CAREER MODELS ============

model Career {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  title             String  @unique
  description       String?
  category          String?
  averageSalary     String?
  jobMarketDemand   Int?    @default(0)
  requiredEducation String?
  yearsExperience   Int?

  // Relations
  skillMappings    CareerSkillMapping[]
  interestMappings CareerInterestMapping[]
  matches          CareerMatch[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CareerSkillMapping {
  id         String @id @default(auto()) @map("_id") @db.ObjectId
  careerId   String @db.ObjectId
  career     Career @relation(fields: [careerId], references: [id], onDelete: Cascade)
  skill      String
  importance Float  @default(1.0)

  createdAt DateTime @default(now())

  @@unique([careerId, skill])
  @@index([careerId])
}

model CareerInterestMapping {
  id         String @id @default(auto()) @map("_id") @db.ObjectId
  careerId   String @db.ObjectId
  career     Career @relation(fields: [careerId], references: [id], onDelete: Cascade)
  interest   String
  importance Float  @default(1.0)

  createdAt DateTime @default(now())

  @@unique([careerId, interest])
  @@index([careerId])
}

model CareerMatch {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  userId            String   @db.ObjectId
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  careerId          String   @db.ObjectId
  career            Career   @relation(fields: [careerId], references: [id], onDelete: Cascade)
  matchScore        Float
  confidenceLevel   String   @default("medium")
  requiredSkills    String[]
  recommendedSkills String[]
  skillGaps         String[]
  educationMatch    Float    @default(0)
  experienceMatch   Float    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, careerId])
  @@index([userId])
  @@index([careerId])
}

// ============ JOB MODELS ============

model Job {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  company     String
  location    String
  description String
  salary      Json?
  skills      String[]
  applyLink   String
  source      String
  createdAt   DateTime @default(now())

  applications JobApplication[]
}

model JobApplication {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId     String   @db.ObjectId
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  status    String   @default("APPLIED")
  appliedAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, jobId])
  @@index([userId])
  @@index([jobId])
}

// ============ AI MEMORY & PERSONALIZATION MODELS ============

model AIMemoryProfile {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  userId         String   @db.ObjectId
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Free-form profile JSON storing aggregated signals, e.g. strengths, weaknesses, preferences
  profileData    Json
  // Compact metrics for quick queries
  compositeScore Float?
  xp             Float    @default(0)
  lastUpdated    DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model RecommendationHistory {
  id             String  @id @default(auto()) @map("_id") @db.ObjectId
  userId         String  @db.ObjectId
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Stores the recommended item and metadata
  recommendation Json
  reason         String?
  score          Float?
  source         String? // e.g., 'assessment', 'ai-engine', 'manual'

  createdAt DateTime @default(now())

  @@index([userId])
}

// Cached AI outputs to avoid repeat Gemini calls for identical prompts
model RecommendationSnapshot {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @db.ObjectId
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind          String
  requestHash   String
  promptVersion String
  provider      String
  model         String
  input         Json?
  response      Json
  expiresAt     DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, kind, requestHash, promptVersion, provider, model])
  @@index([userId])
  @@index([expiresAt])
}

model RoadmapMutation {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Mutation record describing the change: branching, milestone added, pacing adjusted
  mutation  Json
  reason    String?
  appliedAt DateTime @default(now())

  createdAt DateTime @default(now())

  @@index([userId])
}

model PersonalityProfile {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  userId          String   @db.ObjectId
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile         Json // e.g., mentorType, tone, affinity
  confidence      Float?
  lastEvaluatedAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model LearningVelocity {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  windowStart DateTime
  windowEnd   DateTime
  metrics     Json // e.g., tasksCompleted, xpEarned, avgTimePerTask

  createdAt DateTime @default(now())

  @@index([userId])
}

// Persisted snapshots of adaptive decision evaluations for longitudinal analysis
model DecisionSnapshot {
  id       String   @id @default(auto()) @map("_id") @db.ObjectId
  userId   String   @db.ObjectId
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  snapshot Json // full engine output (evaluated list, meta)
  topItems String[] // cached top career titles
  meta     Json? // lightweight meta like avgVelocity, xp, traitCount

  createdAt DateTime @default(now())

  @@index([userId])
}

model MentorConversation {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  journeyId String?  @db.ObjectId
  title     String
  context   Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([journeyId])
}

model MentorMessage {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  conversationId String   @db.ObjectId
  role           String
  content        String
  contextSnapshot Json?

  createdAt DateTime @default(now())

  @@index([conversationId])
}

model CareerJourney {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  slug             String   @unique
  title            String
  roadmapId        String?  @db.ObjectId
  duration         String
  industryDemand   String
  salaryRange      String
  estimatedDays    Int
  requiredSkills   String[]
  learningStructure Json?
  aiContext        Json?
  active           Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([roadmapId])
}

model JourneyDay {
  id               String        @id @default(auto()) @map("_id") @db.ObjectId
  journeyId        String        @db.ObjectId
  dayNumber        Int
  title            String
  focus            String
  topics           String[]
  tasks            Json?
  resources        Json?
  estimatedMinutes Int
  xpReward         Int
  isMilestone      Boolean       @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([journeyId])
  @@index([journeyId, dayNumber])
}

model JourneyTask {
  id               String      @id @default(auto()) @map("_id") @db.ObjectId
  journeyDayId     String      @db.ObjectId
  title            String
  type             String
  estimatedMinutes Int
  xp               Int
  completed        Boolean     @default(false)
  metadata         Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([journeyDayId])
}

model UserJourneyProgress {
  id                 String        @id @default(auto()) @map("_id") @db.ObjectId
  userId             String        @db.ObjectId
  journeyId          String?       @db.ObjectId
  currentDay         Int           @default(1)
  completionPercentage Float        @default(0)
  streak             Int           @default(0)
  xp                 Int           @default(0)
  adaptiveMode       String        @default("growth")
  weakSkills         String[]
  completedSkills    String[]
  nextAction         String?
  lastActiveAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([journeyId])
}

model SkillProgress {
  id             String        @id @default(auto()) @map("_id") @db.ObjectId
  userId         String        @db.ObjectId
  journeyId      String?       @db.ObjectId
  skill          String
  mastery        Float
  completed      Boolean       @default(false)
  weak           Boolean       @default(false)
  progressHistory Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([journeyId])
  @@index([skill])
}

model JobEligibility {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  userId           String   @db.ObjectId
  journeySlug      String
  jobId            String
  title            String
  company          String
  role             String
  location         String
  salary           String?
  requiredSkills   String[]
  missingSkills    String[]
  matchPercentage  Int
  eligible         Boolean  @default(false)
  source           String
  applied          Boolean  @default(false)
  appliedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([journeySlug])
  @@index([jobId])
}

model PlacementReadiness {
  id               String        @id @default(auto()) @map("_id") @db.ObjectId
  userId           String        @db.ObjectId
  journeyId        String?       @db.ObjectId
  score            Int
  label            String
  completedSkills  String[]
  missingSkills    String[]
  eligibleJobs     Int
  nextAction       String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([journeyId])
}
